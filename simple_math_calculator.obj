 203 | 3117 | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\r\n
 204 | 3118 |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\r\n
 205 | 3119 | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\r\n
 206 | 311A |             brz PUSH            ; Putting the new Number into the Stack\r\n
