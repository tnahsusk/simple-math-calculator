 157 | ???? | \n
 158 | 30F1 | DONE        ld R0, NEWLINE\n
 159 | 30F2 |             out\n
 160 | 30F3 |             ld R1, STACK_TOP    ; Checks if the Stack has Extra Numbers\n
 161 | 30F4 |             not R2, R4\n
 162 | 30F5 |             add R2, R2, #1\n
 163 | 30F6 |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 164 | 30F7 |             add R3, R3, #-1     ; Finds the Remaining Amount of Numbers in the Stack after taking 1\n
 165 | 30F8 |             brnp S_ERROR        ; brnp checks if there is more than 1 number in the stack or 0 numbers in the stack\n
 166 | ???? |             \n
