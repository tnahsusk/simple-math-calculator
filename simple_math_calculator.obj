LINE | ADDR | SOURCE
   0 | ???? | ; Simple Math Calculator\n
   1 | ???? | ; LC3-Based Reverse Polish Notation (RPN) Calculator\n
   2 | ???? | \n
   3 | ???? | ; Usage:\n
   4 | ???? | ; Enter a number 0-9, or an operator +, -, *, or /\n
   5 | ???? | ; Calculator will use Reverse Polish Notation to calculate\n
   6 | ???? | ; If there is only one number on stack, operation will fail\n
   7 | ???? | ; and program will terminate. It will accept up to 4 digits.\n
   8 | ???? | ; \".\" will copy the top of the RPN stack into result and terminate\n
   9 | ???? | ; If stack is empty, operation will fail and program will reset to the beginning\n
  10 | ???? | \n
  11 | ???? | ; Algorithm\n
  12 | ???? | ; 1. Initialize RPN stack and test values 0 - 9, +, -, *, /, and . \n
  13 | ???? | ; 2. Print title and instructions\n
  14 | ???? | ; 3. Read character from keyboard\n
  15 | ???? | ; 4. If operator, load operator vector, check stack for two numbers \n
  16 | ???? | ; 5. If so, execute operator vector and push result on stack, if not, error\n
  17 | ???? | ; 6. If number, push number onto stack\n
  18 | ???? | ; 7. If \".\", check if stack is empty, if not copy TOS to result, if so, error\n
  19 | ???? | ; 8. Loop back to 3\n
  20 | ???? | \n
  21 | ???? | ; Registers:\n
  22 | ???? | ; R0 - primary register for operations\n
  23 | ???? | ; R1 - temp register\n
  24 | ???? | ; R2 - temp register\n
  25 | ???? | ; R3 - temp register\n
  26 | ???? | ; R4 - RPN stack pointer\n
  27 | ???? | ; R7 - stores return addresses for JSR calls\n
  28 | ???? | \n
  29 | ???? | ; Prompts:\n
  30 | ???? | ;   > - ready to accept a new number\n
  31 | ???? | ;   ? - error occured, input doesn\'t make sense\n
  32 | ???? | ;   $ - stack error occurred\n
  33 | ???? | ;   ! - numeric overflow or underflow\n
  34 | ???? | \n
  35 | ???? | \n
  36 | ???? | .orig x3000\n
  37 | 3000 |             brnzp START\n
  38 | ???? |             \n
  39 | 3001 | POP2        ldr R2, R4, #0      ; Retrieving the Last Number in the Stack\n
  40 | 3002 |             add R4, R4, #1      ; Incrementing the Stack\n
  41 | 3003 |             ldr R1, R4, #0      ; Retrieving the Next Last Number in the Stack\n
  42 | 3004 |             add R4, R4, #1      ; Incrementing the Stack\n
  43 | 3005 |             ret\n
  44 | ???? | \n
  45 | 3006 | ADDITION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  46 | 3007 |             add R0, R1, R2      ; Adding 2 Most Recent Numbers in the Stack\n
  47 | 3008 |             brnzp PUSH          ; Putting the new Number into the Stack\n
  48 | ???? |             \n
  49 | 3009 | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  50 | 300A |             not R2, R2          ; Negating R2\n
  51 | 300B |             add R2, R2, #1\n
  52 | 300C |             add R0, R2, R1      ; Adding R1 and the Negation of R2\n
  53 | 300D |             brnzp PUSH          ; Putting the new Number into the Stack\n
  54 | ???? |             \n
  55 | 300E | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  56 | 300F |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\n
  57 | 3010 | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\n
  58 | 3011 |             brz PUSH            ; Putting the new Number into the Stack\n
  59 | 3012 |             add R0, R0, R1      ; Repeated Addition\n
  60 | 3013 |             add R2, R2, #-1     ; Decrementing R2 until it is 0\n
  61 | 3014 |             brnzp M_LOOP        \n
  62 | ???? | \n
  63 | 3015 | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  64 | 3016 |             add R3, R2, #0      ; Checking if R2 is 0\n
  65 | 3017 |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\n
  66 | 3018 |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\n
  67 | 3019 | D_LOOP      not R3, R2          ; Negating R2 into R3\n
  68 | 301A |             add R3, R3, #1\n
  69 | 301B |             add R1, R1, R3      ; Addition of R1 and Negation of R3\n
  70 | 301C |             brn PUSH            ; If R1 is not negative yet, the loop repeats, otherwise puts the new Number into the Stack\n
  71 | 301D |             add R0, R0, #1      ; Incrementing R1\n
  72 | 301E |             brnzp D_LOOP\n
  73 | ???? | \n
  74 | 301F | PUSH        add R4, R4, #-1     ; Decrementing the Stack\n
  75 | 3020 |             str R0, R4, #0      ; Storing the New Number into the Stack\n
  76 | 3021 |             brnzp LOOP\n
  77 | ???? |             \n
  78 | 3022 | START       ld R4, STACK_TOP    ; RPN Stack Pointer Address\n
  79 | 3023 |             lea R0, MSG1        ; Printing Title and Instruction\n
  80 | 3024 |             puts\n
  81 | 3025 |             lea R0, MSG2\n
  82 | 3026 |             puts\n
  83 | 3027 |             lea R0, MSG3\n
  84 | 3028 |             puts\n
  85 | ???? | \n
  86 | 3029 | LOOP        lea R0, NEW_NUM      ; Asking for a New Number/Operator\n
  87 | 302A |             puts\n
  88 | 302B |             getc\n
  89 | 302C |             out\n
  90 | 302D |             add R1, R0, #0      ; Transferring the new number to R1\n
  91 | 302E |             ld R0, NEWLINE\n
  92 | 302F |             out\n
  93 | 3030 |             add R0, R1, #0      ; Transferring the number back to R0\n
  94 | ???? |             \n
  95 | 3031 |             ld R1, MULT         ; Setting R1 to \"*\" and turning it to its negative decimal value\n
  96 | 3032 |             not R1, R1\n
  97 | 3033 |             add R1, R1, #1\n
  98 | 3034 |             add R2, R0, R1      ; If R2 is negative, that means the input is not a valid input (decimal value is too small)\n
  99 | 3035 |             brn ERROR\n
 100 | ???? |             \n
 101 | 3036 |             ld R1, ASCII_0      ; Setting R1 to ASCII 0 and turning it to its negative decimal value\n
 102 | 3037 |             not R1, R1\n
 103 | 3038 |             add R1, R1, #1\n
 104 | 3039 |             add R2, R0, R1      ; Since we checked the lower bound, anything less than ASCII 0 will be either a valid operator or \",\"\n
 105 | 303A |             brn CHECK_OP\n
 106 | 303B |             add R2, R2, #-9     ; If R2 is negative, that means the input is not a valid input (decimal value is too large)\n
 107 | 303C |             brp ERROR\n
 108 | ???? |             \n
 109 | 303D |             ld R1, ASCII_0      ; Resetting R1 to ASCII 0 and turning it to its negative decimal value\n
 110 | 303E |             not R1, R1\n
 111 | 303F |             add R1, R1, #1\n
 112 | 3040 |             add R0, R0, R1      ; Converting the ASCII digit to an integer\n
 113 | 3041 |             add R4, R4, #-1     ; Decrementing the R4 and repeating the Loop until CHECK_OP notices a \".\" or an error occurs\n
 114 | 3042 |             str R0, R4, #0      ; Storing the integer in R4 (RPN Stack Pointer)\n
 115 | 3043 |             brnzp LOOP\n
 116 | ???? |             \n
 117 | 3044 | CHECK_OP    ld R1, STACK_TOP   ; Checks if the Stack has 2 Available Numbers to use for the Operation\n
 118 | 3045 |             not R2, R4\n
 119 | 3046 |             add R2, R2, #1\n
 120 | 3047 |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 121 | 3048 |             add R3, R3, #2      ; Finds the Remaining Amount of Numbers in the Stack after taking 2\n
 122 | 3049 |             brn S_ERROR\n
 123 | ???? |             \n
 124 | 304A |             ld R1, MULT         ; Checking if the Operator is the Multiplication Symbol\n
 125 | 304B |             not R1, R1\n
 126 | 304C |             add R1, R1, #1\n
 127 | 304D |             add R2, R0, R1\n
 128 | 304E |             brz MULTIPLY\n
 129 | ???? |             \n
 130 | 304F |             ld R1, PLUS         ; Checking if the Operator is the Addition Symbol\n
 131 | 3050 |             not R1, R1\n
 132 | 3051 |             add R1, R1, #1\n
 133 | 3052 |             add R2, R0, R1\n
 134 | 3053 |             brz ADDITION\n
 135 | ???? |             \n
 136 | 3054 |             ld R1, MINUS        ; Checking if the Operator is the Subtraction Symbol\n
 137 | 3055 |             not R1, R1\n
 138 | 3056 |             add R1, R1, #1\n
 139 | 3057 |             add R2, R0, R1\n
 140 | 3058 |             brz SUBTRACTION\n
 141 | ???? |             \n
 142 | 3059 |             ld R1, DIVIDE       ; Checking if the Operator is the Division Symbol\n
 143 | 305A |             not R1, R1\n
 144 | 305B |             add R1, R1, #1\n
 145 | 305C |             add R2, R0, R1\n
 146 | 305D |             brz DIVISION\n
 147 | ???? |             \n
 148 | 305E |             ld R1, TOS          ; Checking if the Operator is \".\"\n
 149 | 305F |             not R1, R1\n
 150 | 3060 |             add R1, R1, #1\n
 151 | 3061 |             add R2, R0, R1\n
 152 | 3062 |             brz DONE\n
 153 | ???? |             \n
 154 | 3063 |             brnzp ERROR         ; Input is \",\" which is an disallowed input\n
 155 | ???? | \n
 156 | 3064 | DONE        ldr R0, R4, #0      ; Takes the current value in R4\n
 157 | 3065 |             st R0, result       ; Stores it into result\n
 158 | 3066 |             ld R1, ASCII_0      ; Loades in ASCII_0 to convert R0 to ASCII\n
 159 | 3067 |             add R0, R0, R1\n
 160 | 3068 |             out                 ; Prints out the ASCII of whatever number is R0\n
 161 | 3069 |             brnzp EXIT\n
 162 | ???? | \n
 163 | 306A | ERROR       lea R0, INPUT_ERROR ; Input Error\n
 164 | 306B |             puts\n
 165 | 306C |             ld R0, NEWLINE\n
 166 | 306D |             out\n
 167 | 306E |             brnzp START         ; Restarting Program\n
 168 | ???? |             \n
 169 | 306F | S_ERROR     lea R0, STACK_ERROR ; Stack Error\n
 170 | 3070 |             puts\n
 171 | 3071 |             ld R0, NEWLINE\n
 172 | 3072 |             out\n
 173 | 3073 |             brnzp START         ; Restarting Program\n
 174 | ???? | \n
 175 | 3074 | F_ERROR     lea R0, FLOW_ERROR  ; Numeric Overflow or Underflow\n
 176 | 3075 |             puts\n
 177 | 3076 |             ld R0, NEWLINE\n
 178 | 3077 |             out\n
 179 | 3078 |             brnzp START         ; Restarting Program\n
 180 | ???? |             \n
 181 | 3079 | EXIT        halt\n
 182 | ???? |             \n
 183 | 307A | result      .blkw 1\n
 184 | 307B | MULT        .fill x2A\n
 185 | 307C | PLUS        .fill x2B\n
 186 | 307D | MINUS       .fill x2D\n
 187 | 307E | DIVIDE      .fill x2F\n
 188 | 307F | TOS         .fill x2E\n
 189 | 3080 | ASCII_0     .fill x30\n
 190 | 3081 | STACK_TOP   .fill x4000\n
 191 | ???? | \n
 192 | 3082 | MSG1        .stringz \"SMC RPN Calculator\\n\"\n
 193 | 3096 | MSG2        .stringz \"Enter 0-9 or +, -, *, /, or . to display result on TOS.\\n\"\n
 194 | 30CF | MSG3        .stringz \"It will accept up to 4 numeric digits and perform operations.\\n\"\n
 195 | 310E | NEW_NUM     .stringz \"> \"\n
