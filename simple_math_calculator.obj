 213 | 3120 |             brnzp PUSH          ; Putting the new Number into the Stack\r\n
 214 | ???? | \r\n
 215 | 3121 | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\r\n
 216 | 3122 |             not R2, R2          ; Negating R2\r\n
 217 | 3123 |             add R2, R2, #1\r\n
 218 | 3124 |             add R0, R2, R1      ; Adding R1 and the Negation of R2\r\n
 219 | 3125 |             brnzp PUSH          ; Putting the new Number into the Stack\r\n
 220 | ???? | \r\n
 221 | 3126 | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\r\n
 222 | 3127 |             add R3, R2, #0      ; Checking if R2 is 0\r\n
 223 | 3128 |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\r\n
 224 | 3129 |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\r\n
 225 | 312A |             and R3, R3, #0      ; Keeps record if the quotient should be positive (0) or negative (1)\r\n
 226 | 312B |             add R1, R1, #0\r\n
 227 | 312C |             brzp SKIP           ; Checks if R1 (dividend) is negative or not\r\n
 228 | 312D |             not R1, R1\r\n
 229 | 312E |             add R1, R1, #1      ; Negating R1\r\n
 230 | 312F |             add R3, R3, #1      ; Changes R3 to negative\r\n
 231 | 3130 | SKIP        add R2, R2, #0\r\n
 232 | 3131 |             brzp D_LOOP         ; Checks if R2 (divisor) is negative or not\r\n
 233 | 3132 |             not R2, R2\r\n
 234 | 3133 |             add R2, R2, #1      ; Negating R2\r\n
 235 | 3134 |             add R3, R3, #1\r\n
 236 | 3135 | D_LOOP      not R5, R2          ; Negating R2 into R5 (R5 is a temp register here)\r\n
 237 | 3136 |             add R5, R5, #1\r\n
 238 | 3137 |             add R1, R1, R5      ; Addition of R1 and Negation of R5\r\n
 239 | 3138 |             brn D_DONE          ; If R1 is not negative yet, the loop repeats, otherwise make quotient the correct sign then push to stack\r\n
 240 | 3139 |             add R0, R0, #1      ; Incrementing R1\r\n
 241 | 313A |             brnzp D_LOOP\r\n
 242 | 313B | D_DONE      add R3, R3, #-1\r\n
 243 | 313C |             brnp PUSH           ; If R3 was 0 or 2 originally (positive), then now it is -1 or 1 and will be pushed to stack\r\n
 244 | 313D |             not R0, R0          ; Otherwise R0 will be negated\r\n
 245 | 313E |             add R0, R0, #1\r\n
 246 | 313F |             brnzp PUSH\r\n
 247 | ???? |             \r\n
 248 | 3140 | POP2        ldr R2, R4, #0      ; Retrieving the Last Number in the Stack\r\n
 249 | 3141 |             add R4, R4, #1      ; Incrementing the Stack\r\n
 250 | 3142 |             ldr R1, R4, #0      ; Retrieving the Next Last Number in the Stack\r\n
 251 | 3143 |             add R4, R4, #1      ; Incrementing the Stack\r\n
 252 | 3144 |             ret\r\n
