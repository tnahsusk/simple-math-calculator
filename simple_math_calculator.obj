LINE | ADDR | SOURCE
   0 | ???? | ; Simple Math Calculator\n
   1 | ???? | ; LC3-Based Reverse Polish Notation (RPN) Calculator\n
   2 | ???? | \n
   3 | ???? | ; Usage:\n
   4 | ???? | ; Enter a number 0-9, or an operator +, -, *, or /\n
   5 | ???? | ; Calculator will use Reverse Polish Notation to calculate\n
   6 | ???? | ; If there is only one number on stack, operation will fail\n
   7 | ???? | ; and program will terminate. It will accept up to 4 digits.\n
   8 | ???? | ; \".\" will copy the top of the RPN stack into result and terminate\n
   9 | ???? | ; If stack is empty, operation will fail and program will reset to the beginning\n
  10 | ???? | \n
  11 | ???? | ; Algorithm\n
  12 | ???? | ; 1. Initialize RPN stack and test values 0 - 9, +, -, *, /, and . \n
  13 | ???? | ; 2. Print title and instructions\n
  14 | ???? | ; 3. Read character from keyboard\n
  15 | ???? | ; 4. If operator, load operator vector, check stack for two numbers \n
  16 | ???? | ; 5. If so, execute operator vector and push result on stack, if not, error\n
  17 | ???? | ; 6. If number, push number onto stack\n
  18 | ???? | ; 7. If \".\", check if stack is empty, if not copy TOS to result, if so, error\n
  19 | ???? | ; 8. Loop back to 3\n
  20 | ???? | \n
  21 | ???? | ; Registers:\n
  22 | ???? | ; R0 - primary register for operations\n
  23 | ???? | ; R1 - temp register\n
  24 | ???? | ; R2 - temp register\n
  25 | ???? | ; R3 - temp register\n
  26 | ???? | ; R4 - RPN stack pointer\n
  27 | ???? | ; R7 - stores return addresses for JSR calls\n
  28 | ???? | \n
  29 | ???? | ; Prompts:\n
  30 | ???? | ;   > - ready to accept a new number\n
  31 | ???? | ;   ? - error occured, input doesn\'t make sense\n
  32 | ???? | ;   $ - stack error occurred\n
  33 | ???? | ;   ! - numeric overflow or underflow\n
  34 | ???? | \n
  35 | ???? | \n
  36 | ???? | .orig x3000\n
  37 | 3000 |             brnzp START\n
  38 | ???? |             \n
  39 | 3001 | POP2        ldr R2, R4, #0      ; Retrieving the Last Number in the Stack\n
  40 | 3002 |             add R4, R4, #1      ; Incrementing the Stack\n
  41 | 3003 |             ldr R1, R4, #0      ; Retrieving the Next Last Number in the Stack\n
  42 | 3004 |             add R4, R4, #1      ; Incrementing the Stack\n
  43 | 3005 |             ret\n
  44 | ???? | \n
  45 | 3006 | ADDITION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  46 | 3007 |             add R0, R1, R2      ; Adding 2 Most Recent Numbers in the Stack\n
  47 | 3008 |             brnzp PUSH          ; Putting the new Number into the Stack\n
  48 | ???? |             \n
  49 | 3009 | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  50 | 300A |             not R2, R2          ; Negating R2\n
  51 | 300B |             add R2, R2, #1\n
  52 | 300C |             add R0, R2, R1      ; Adding R1 and the Negation of R2\n
  53 | 300D |             brnzp PUSH          ; Putting the new Number into the Stack\n
  54 | ???? |             \n
  55 | 300E | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  56 | 300F |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\n
  57 | 3010 | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\n
  58 | 3011 |             brz PUSH            ; Putting the new Number into the Stack\n
  59 | 3012 |             add R0, R0, R1      ; Repeated Addition\n
  60 | 3013 |             add R2, R2, #-1     ; Decrementing R2 until it is 0\n
  61 | 3014 |             brnzp M_LOOP        \n
  62 | ???? | \n
  63 | 3015 | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
  64 | 3016 |             add R3, R2, #0      ; Checking if R2 is 0\n
  65 | 3017 |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\n
  66 | 3018 |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\n
  67 | 3019 | D_LOOP      not R3, R2          ; Negating R2 into R3\n
  68 | 301A |             add R3, R3, #1\n
  69 | 301B |             add R1, R1, R3      ; Addition of R1 and Negation of R3\n
  70 | 301C |             brn PUSH            ; If R1 is not negative yet, the loop repeats, otherwise puts the new Number into the Stack\n
  71 | 301D |             add R0, R0, #1      ; Incrementing R1\n
  72 | 301E |             brnzp D_LOOP\n
  73 | ???? | \n
  74 | 301F | PUSH        add R4, R4, #-1     ; Decrementing the Stack\n
  75 | 3020 |             str R0, R4, #0      ; Storing the New Number into the Stack\n
  76 | ???? |             \n
  77 | 3021 | START       ld R4, STACK_TOP    ; RPN Stack Pointer Address\n
  78 | 3022 |             lea R0, MSG1        ; Printing Title and Instruction\n
  79 | 3023 |             puts\n
  80 | 3024 |             lea R0, MSG2\n
  81 | 3025 |             puts\n
  82 | 3026 |             lea R0, MSG3\n
  83 | 3027 |             puts\n
  84 | ???? | \n
  85 | 3028 | LOOP        lea R0, NEW_NUM      ; Asking for a New Number/Operator\n
  86 | 3029 |             puts\n
  87 | 302A |             getc\n
  88 | 302B |             add R1, R0, #0      ; Transferring the new number to R1\n
  89 | 302C |             ld R0, NEWLINE\n
  90 | 302D |             out\n
  91 | 302E |             add R0, R1, #0      ; Transferring the number back to R0\n
  92 | ???? |             \n
  93 | 302F |             ld R1, MULT         ; Setting R1 to \"*\" and turning it to its negative decimal value\n
  94 | 3030 |             not R1, R1\n
  95 | 3031 |             add R1, R1, #1\n
  96 | 3032 |             add R2, R0, R1      ; If R2 is negative, that means the input is not a valid input (decimal value is too small)\n
  97 | 3033 |             brn ERROR\n
  98 | ???? |             \n
  99 | 3034 |             ld R1, ASCII_0      ; Setting R1 to ASCII 0 and turning it to its negative decimal value\n
 100 | 3035 |             not R1, R1\n
 101 | 3036 |             add R1, R1, #1\n
 102 | 3037 |             add R2, R0, R1      ; Since we checked the lower bound, anything less than ASCII 0 will be either a valid operator or \",\"\n
 103 | 3038 |             brn CHECK_OP\n
 104 | 3039 |             add R2, R2, #-9     ; If R2 is negative, that means the input is not a valid input (decimal value is too large)\n
 105 | 303A |             brn ERROR\n
 106 | ???? |             \n
 107 | 303B |             ld R1, ASCII_0      ; Resetting R1 to ASCII 0 and turning it to its negative decimal value\n
 108 | 303C |             not R1, R1\n
 109 | 303D |             add R1, R1, #1\n
 110 | 303E |             add R0, R0, R1      ; Converting the ASCII digit to an integer\n
 111 | 303F |             add R4, R4, #-1     ; Decrementing the R4 and repeating the Loop until CHECK_OP notices a \".\" or an error occurs\n
 112 | 3040 |             str R0, R4, #0      ; Storing the integer in R4 (RPN Stack Pointer)\n
 113 | 3041 |             brnzp LOOP\n
 114 | ???? |             \n
 115 | 3042 | CHECK_OP    ld R1, STACK_TOP   ; Checks if the Stack has 2 Available Numbers to use for the Operation\n
 116 | 3043 |             not R2, R4\n
 117 | 3044 |             add R2, R2, #1\n
 118 | 3045 |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 119 | 3046 |             add R3, R3, #2      ; Finds the Remaining Amount of Numbers in the Stack after taking 2\n
 120 | 3047 |             brn S_ERROR\n
 121 | ???? |             \n
 122 | 3048 |             ld R1, MULT         ; Checking if the Operator is the Multiplication Symbol\n
 123 | 3049 |             not R1, R1\n
 124 | 304A |             add R1, R1, #1\n
 125 | 304B |             add R2, R0, R1\n
 126 | 304C |             brz MULTIPLY\n
 127 | ???? |             \n
 128 | 304D |             ld R1, PLUS         ; Checking if the Operator is the Addition Symbol\n
 129 | 304E |             not R1, R1\n
 130 | 304F |             add R1, R1, #1\n
 131 | 3050 |             add R2, R0, R1\n
 132 | 3051 |             brz ADDITION\n
 133 | ???? |             \n
 134 | 3052 |             ld R1, MINUS        ; Checking if the Operator is the Subtraction Symbol\n
 135 | 3053 |             not R1, R1\n
 136 | 3054 |             add R1, R1, #1\n
 137 | 3055 |             add R2, R0, R1\n
 138 | 3056 |             brz SUBTRACTION\n
 139 | ???? |             \n
 140 | 3057 |             ld R1, DIVIDE       ; Checking if the Operator is the Division Symbol\n
 141 | 3058 |             not R1, R1\n
 142 | 3059 |             add R1, R1, #1\n
 143 | 305A |             add R2, R0, R1\n
 144 | 305B |             brz DIVISION\n
 145 | ???? |             \n
 146 | 305C |             ld R1, TOS          ; Checking if the Operator is \".\"\n
 147 | 305D |             not R1, R1\n
 148 | 305E |             add R1, R1, #1\n
 149 | 305F |             add R2, R0, R1\n
 150 | 3060 |             brz DONE\n
 151 | ???? |             \n
 152 | 3061 |             brnzp ERROR         ; Input is \",\" which is an disallowed input\n
 153 | ???? | \n
 154 | 3062 | DONE        ldr R0, R4, #0\n
 155 | 3063 |             st R0, result\n
 156 | 3064 |             brnzp EXIT\n
 157 | ???? | \n
 158 | 3065 | ERROR       ld R0, INPUT_ERROR  ; Input Error\n
 159 | 3066 |             puts\n
 160 | 3067 |             ld R0, NEWLINE\n
 161 | 3068 |             out\n
 162 | 3069 |             brnzp START         ; Restarting Program\n
 163 | ???? |             \n
 164 | 306A | S_ERROR     ld R0, STACK_ERROR  ; Stack Error\n
 165 | 306B |             puts\n
 166 | 306C |             ld R0, NEWLINE\n
 167 | 306D |             out\n
 168 | 306E |             brnzp START         ; Restarting Program\n
 169 | ???? | \n
 170 | 306F | F_ERROR     ld R0, FLOW_ERROR   ; Numeric Overflow or Underflow\n
 171 | 3070 |             puts\n
 172 | 3071 |             ld R0, NEWLINE\n
 173 | 3072 |             out\n
 174 | 3073 |             brnzp START         ; Restarting Program\n
 175 | ???? |             \n
 176 | 3074 | EXIT        halt\n
 177 | ???? |             \n
 178 | 3075 | result      .blkw 1\n
 179 | 3076 | MULT        .fill x2A\n
 180 | 3077 | PLUS        .fill x2B\n
 181 | 3078 | MINUS       .fill x2D\n
 182 | 3079 | DIVIDE      .fill x2F\n
 183 | 307A | TOS         .fill x2E\n
 184 | 307B | ASCII_0     .fill x30\n
 185 | 307C | STACK_TOP   .fill x4000\n
 186 | ???? | \n
 187 | 307D | MSG1        .stringz \"SMC RPN Calculator\\n\"\n
 188 | 3091 | MSG2        .stringz \"Enter 0-9 or +, -, *, /, or . to display result on TOS.\\n\"\n
 189 | 30CA | MSG3        .stringz \"It will accept up to 4 numeric digits and perform operations.\\n\"\n
 190 | 3109 | NEW_NUM     .stringz \"> \"\n
