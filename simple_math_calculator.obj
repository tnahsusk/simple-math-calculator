 209 | 311C |             add R2, R0, R1\n
 210 | 311D |             brz DIVISION\n
 211 | ???? |             \n
 212 | 311E |             brnzp ERROR         ; Input is \",\" which is an disallowed input\n
 213 | ???? | \n
 214 | 311F | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 215 | 3120 |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\n
 216 | 3121 | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\n
 217 | 3122 |             brz PUSH            ; Putting the new Number into the Stack\n
 218 | 3123 |             add R0, R0, R1      ; Repeated Addition\n
 219 | 3124 |             add R2, R2, #-1     ; Decrementing R2 until it is 0\n
 220 | 3125 |             brnzp M_LOOP\n
 221 | ???? | \n
 222 | 3126 | ADDITION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
