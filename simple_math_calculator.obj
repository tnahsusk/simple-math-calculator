 140 | ???? | \n
 141 | 30D9 | STACK_TOP   .fill x4000\n
 142 | 30DA | NEW_NUM     .stringz \"> \"\n
 143 | 30DD | INPUT_ERROR .stringz \"? \"\n
 144 | 30E0 | STACK_ERROR .stringz \"$ \"\n
 145 | 30E3 | FLOW_ERROR  .stringz \"! \"\n
