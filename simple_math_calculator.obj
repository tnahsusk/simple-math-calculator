====================
LINE | ADDR | SOURCE
   0 | ???? | ; Simple Math Calculator\n
   1 | ???? | ; LC3-Based Reverse Polish Notation (RPN) Calculator\n
   2 | ???? | \n
   3 | ???? | ; Usage:\n
   4 | ???? | ; Enter a number 0-9, or an operator +, -, *, or /\n
   5 | ???? | ; Calculator will use Reverse Polish Notation to calculate\n
   6 | ???? | ; If there is only one number on stack, operation will fail\n
   7 | ???? | ; and program will terminate. It will accept up to 4 digits.\n
   8 | ???? | ; \".\" will copy the top of the RPN stack into result and terminate\n
   9 | ???? | ; If stack is empty, operation will fail and program will reset to the beginning\n
  10 | ???? | \n
  11 | ???? | ; Algorithm\n
  12 | ???? | ; 1. Initialize RPN stack and test values 0 - 9, +, -, *, /, and . \n
  13 | ???? | ; 2. Print title and instructions\n
  14 | ???? | ; 3. Read character from keyboard\n
  15 | ???? | ; 4. If operator, load operator vector, check stack for two numbers \n
  16 | ???? | ; 5. If so, execute operator vector and push result on stack, if not, error\n
  17 | ???? | ; 6. If number, push number onto stack\n
  18 | ???? | ; 7. If \".\", check if stack is empty, if not copy TOS to result, if so, error\n
  19 | ???? | ; 8. Loop back to 3\n
  20 | ???? | \n
  21 | ???? | ; Registers:\n
  22 | ???? | ; R0 - primary register for operations\n
  23 | ???? | ; R1 - temp register\n
  24 | ???? | ; R2 - temp register\n
  25 | ???? | ; R3 - temp register\n
  26 | ???? | ; R4 - RPN stack pointer\n
  27 | ???? | ; R7 - stores return addresses for JSR calls\n
  28 | ???? | \n
  29 | ???? | ; Prompts:\n
  30 | ???? | ;   > - ready to accept a new number\n
  31 | ???? | ;   ? - error occured, input doesn\'t make sense\n
  32 | ???? | ;   $ - stack error occurred\n
  33 | ???? | ;   ! - numeric overflow or underflow\n
  34 | ???? | \n
  35 | ???? | \n
  36 | ???? | .orig x3000\n
  37 | ???? | \n
  38 | 3000 | START       ld R4, STACK_TOP    ; RPN Stack Pointer Address\n
  39 | 3001 |             lea R0, MSG1        ; Printing Title and Instruction\n
  40 | 3002 |             puts\n
  41 | 3003 |             lea R0, MSG2\n
  42 | 3004 |             puts\n
  43 | 3005 |             lea R0, MSG3\n
  44 | 3006 |             puts\n
  45 | ???? |             \n
  46 | 3007 | LOOP        lea R0, NEW_NUM      ; Asking for a New Number/Operator\n
  47 | 3008 |             puts\n
  48 | 3009 |             getc\n
  49 | 300A |             out\n
  50 | 300B |             add R1, R0, #0      ; Transferring the new number to R1\n
  51 | 300C |             ld R0, NEWLINE\n
  52 | 300D |             out\n
  53 | 300E |             add R0, R1, #0      ; Transferring the number back to R0\n
  54 | ???? |             \n
  55 | 300F |             ld R1, MULT         ; Setting R1 to \"*\" and turning it to its negative decimal value\n
  56 | 3010 |             not R1, R1\n
  57 | 3011 |             add R1, R1, #1\n
  58 | 3012 |             add R2, R0, R1      ; If R2 is negative, that means the input is not a valid input (decimal value is too small)\n
  59 | 3013 |             brn ERROR\n
  60 | ???? |             \n
  61 | 3014 |             ld R1, ASCII_0      ; Setting R1 to ASCII 0 and turning it to its negative decimal value\n
  62 | 3015 |             not R1, R1\n
  63 | 3016 |             add R1, R1, #1\n
  64 | 3017 |             add R2, R0, R1      ; Since we checked the lower bound, anything less than ASCII 0 will be either a valid operator or \",\"\n
  65 | 3018 |             brn CHECK_OP\n
  66 | 3019 |             add R2, R2, #-9     ; If R2 is negative, that means the input is not a valid input (decimal value is too large)\n
  67 | 301A |             brp ERROR\n
  68 | ???? |             \n
  69 | 301B |             ld R1, ASCII_0      ; Resetting R1 to ASCII 0 and turning it to its negative decimal value\n
  70 | 301C |             not R1, R1\n
  71 | 301D |             add R1, R1, #1\n
  72 | 301E |             add R0, R0, R1      ; Converting the ASCII digit to an integer\n
  73 | 301F |             add R4, R4, #-1     ; Decrementing the R4 and repeating the Loop until CHECK_OP notices a \".\" or an error occurs\n
  74 | 3020 |             str R0, R4, #0      ; Storing the integer in R4 (RPN Stack Pointer)\n
  75 | 3021 |             brnzp LOOP\n
  76 | ???? | \n
  77 | 3022 | S_ERROR     lea R0, STACK_ERROR ; Stack Error\n
  78 | 3023 |             puts\n
  79 | 3024 |             ld R0, NEWLINE\n
  80 | 3025 |             out\n
  81 | 3026 |             brnzp START         ; Restarting Program\n
  82 | ???? | \n
  83 | 3027 | F_ERROR     lea R0, FLOW_ERROR  ; Numeric Overflow or Underflow\n
  84 | 3028 |             puts\n
  85 | 3029 |             ld R0, NEWLINE\n
  86 | 302A |             out\n
  87 | 302B |             brnzp START         ; Restarting Program\n
  88 | ???? | \n
  89 | 302C | ERROR       lea R0, INPUT_ERROR ; Input Error\n
  90 | 302D |             puts\n
  91 | 302E |             ld R0, NEWLINE\n
  92 | 302F |             out\n
  93 | 3030 |             brnzp START         ; Restarting Program\n
  94 | ???? | \n
  95 | 3031 | EXIT        halt\n
  96 | ???? | \n
  97 | 3032 | result      .blkw 1             ; Result from the Calculator (Will also be Printed in the Console unless the number is greater than 9 or less than -9)\n
  98 | 3033 | STACK_TOP   .fill x4000\n
  99 | 3034 | NEW_NUM     .stringz \"> \"\n
 100 | 3037 | INPUT_ERROR .stringz \"? \"\n
 101 | 303A | STACK_ERROR .stringz \"$ \"\n
 102 | 303D | FLOW_ERROR  .stringz \"! \"\n
 103 | 3040 | NEWLINE     .fill x000A\n
 104 | 3041 | MULT        .fill x2A\n
 105 | 3042 | PLUS        .fill x2B\n
 106 | 3043 | MINUS       .fill x2D\n
 107 | 3044 | DIVIDE      .fill x2F\n
 108 | 3045 | TOS         .fill x2E\n
 109 | 3046 | ASCII_0     .fill x30\n
 110 | ???? | \n
 111 | 3047 | DONE        ld R1, STACK_TOP    ; Checks if the Stack has Extra Numbers\n
 112 | 3048 |             not R2, R4\n
 113 | 3049 |             add R2, R2, #1\n
 114 | 304A |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 115 | 304B |             add R3, R3, #-1     ; Finds the Remaining Amount of Numbers in the Stack after taking 1\n
 116 | 304C |             brnp S_ERROR        ; brnp checks if there is more than 1 number in the stack or 0 numbers in the stack\n
 117 | ???? |             \n
 118 | 304D |             ldr R0, R4, #0      ; Takes the current value in R4\n
 119 | 304E |             st R0, result       ; Stores it into result\n
 120 | 304F |             brn NEGATIVE        ; If it is negative, a negative sign needs to be outputted and the number has to be converted to positive\n
 121 | 3050 |             add R1, R0, #-9     ; Checks if R0 is greater than 9\n
 122 | 3051 |             brp DOUBLEDIGIT\n
 123 | 3052 | BACK        ld R1, ASCII_0      ; Loads in ASCII_0 to convert R0 to ASCII\n
 124 | 3053 |             add R0, R0, R1\n
 125 | 3054 |             out                 ; Prints out the ASCII of whatever number is R0\n
 126 | 3055 |             brnzp EXIT\n
 127 | ???? | \n
 128 | 3056 | CHECK_OP    ld R1, TOS          ; Checking if the Operator is \".\"\n
 129 | 3057 |             not R1, R1\n
 130 | 3058 |             add R1, R1, #1\n
 131 | 3059 |             add R2, R0, R1\n
 132 | 305A |             brz DONE\n
 133 | ???? |             \n
 134 | 305B |             ld R1, STACK_TOP    ; Checks if the Stack has 2 Available Numbers to use for the Operation\n
 135 | 305C |             not R2, R4\n
 136 | 305D |             add R2, R2, #1\n
 137 | 305E |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 138 | 305F |             add R3, R3, #-2     ; Finds the Remaining Amount of Numbers in the Stack after taking 2\n
 139 | 3060 |             brn S_ERROR\n
 140 | ???? |             \n
 141 | 3061 |             ld R1, MULT         ; Checking if the Operator is the Multiplication Symbol\n
 142 | 3062 |             not R1, R1\n
 143 | 3063 |             add R1, R1, #1\n
 144 | 3064 |             add R2, R0, R1\n
 145 | 3065 |             brz MULTIPLY\n
 146 | ???? |             \n
 147 | 3066 |             ld R1, PLUS         ; Checking if the Operator is the Addition Symbol\n
 148 | 3067 |             not R1, R1\n
 149 | 3068 |             add R1, R1, #1\n
 150 | 3069 |             add R2, R0, R1\n
 151 | 306A |             brz ADDITION\n
 152 | ???? |             \n
 153 | 306B |             ld R1, MINUS        ; Checking if the Operator is the Subtraction Symbol\n
 154 | 306C |             not R1, R1\n
 155 | 306D |             add R1, R1, #1\n
 156 | 306E |             add R2, R0, R1\n
 157 | 306F |             brz SUBTRACTION\n
 158 | ???? |             \n
 159 | 3070 |             ld R1, DIVIDE       ; Checking if the Operator is the Division Symbol\n
 160 | 3071 |             not R1, R1\n
 161 | 3072 |             add R1, R1, #1\n
 162 | 3073 |             add R2, R0, R1\n
 163 | 3074 |             brz DIVISION\n
 164 | ???? |             \n
 165 | 3075 |             brnzp ERROR         ; Input is \",\" which is an disallowed input\n
 166 | ???? |             \n
 167 | 3076 | NEGATIVE    add R1, R0, #9      ; Checks if R0 is less than -9\n
 168 | 3077 |             brn DOUBLEDIGIT\n
 169 | ???? |             \n
 170 | 3078 |             ld R0, MINUS        ; Outputs a negative sign\n
 171 | 3079 |             out\n
 172 | 307A |             ld R0, result       ; Negates R0 AFTER it is already stored in result\n
 173 | 307B |             not R0, R0\n
 174 | 307C |             add R0, R0, #1\n
 175 | 307D |             brnzp BACK          ; Returns to where it was originally, but positive\n
 176 | ???? | \n
 177 | 307E | DOUBLEDIGIT lea R0, MSG4        ; Prints that the number is greater than 9 or less than -9 in console\n
 178 | 307F |             puts\n
 179 | 3080 |             brnzp EXIT\n
 180 | ???? | \n
 181 | 3081 | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 182 | 3082 |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\n
 183 | 3083 | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\n
 184 | 3084 |             brz PUSH            ; Putting the new Number into the Stack\n
 185 | 3085 |             add R0, R0, R1      ; Repeated Addition\n
 186 | 3086 |             add R2, R2, #-1     ; Decrementing R2 until it is 0\n
 187 | 3087 |             brnzp M_LOOP\n
 188 | ???? | \n
 189 | 3088 | ADDITION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 190 | 3089 |             add R0, R1, R2      ; Adding 2 Most Recent Numbers in the Stack\n
 191 | 308A |             brnzp PUSH          ; Putting the new Number into the Stack\n
 192 | ???? | \n
 193 | 308B | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 194 | 308C |             not R2, R2          ; Negating R2\n
 195 | 308D |             add R2, R2, #1\n
 196 | 308E |             add R0, R2, R1      ; Adding R1 and the Negation of R2\n
 197 | 308F |             brnzp PUSH          ; Putting the new Number into the Stack\n
 198 | ???? | \n
 199 | 3090 | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 200 | 3091 |             add R3, R2, #0      ; Checking if R2 is 0\n
 201 | 3092 |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\n
 202 | 3093 |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\n
 203 | 3094 | D_LOOP      not R3, R2          ; Negating R2 into R3\n
 204 | 3095 |             add R3, R3, #1\n
 205 | 3096 |             add R1, R1, R3      ; Addition of R1 and Negation of R3\n
 206 | 3097 |             brn PUSH            ; If R1 is not negative yet, the loop repeats, otherwise puts the new Number into the Stack\n
 207 | 3098 |             add R0, R0, #1      ; Incrementing R1\n
 208 | 3099 |             brnzp D_LOOP\n
 209 | ???? | \n
 210 | 309A | PUSH        add R4, R4, #-1     ; Decrementing the Stack\n
 211 | 309B |             str R0, R4, #0      ; Storing the New Number into the Stack\n
 212 | 309C |             brnzp LOOP\n
 213 | ???? | \n
 214 | 309D | POP2        ldr R2, R4, #0      ; Retrieving the Last Number in the Stack\n
 215 | 309E |             add R4, R4, #1      ; Incrementing the Stack\n
 216 | 309F |             ldr R1, R4, #0      ; Retrieving the Next Last Number in the Stack\n
 217 | 30A0 |             add R4, R4, #1      ; Incrementing the Stack\n
 218 | 30A1 |             ret\n
 219 | ???? | \n
 220 | 30A2 | MSG1        .stringz \"SMC RPN Calculator\\n\"\n
 221 | 30B6 | MSG2        .stringz \"Enter 0-9 or +, -, *, /, or . to display result on TOS.\\n\"\n
 222 | 30EF | MSG3        .stringz \"It will accept up to 4 numeric digits and perform operations.\\n\"\n
 223 | 312E | MSG4        .stringz \"Number is greater than 9 or less than -9, check result.\"\n
 224 | ???? | .end
