 224 | 3128 |             brnzp PUSH          ; Putting the new Number into the Stack\n
 225 | ???? | \n
 226 | 3129 | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 227 | 312A |             not R2, R2          ; Negating R2\n
 228 | 312B |             add R2, R2, #1\n
 229 | 312C |             add R0, R2, R1      ; Adding R1 and the Negation of R2\n
 230 | 312D |             brnzp PUSH          ; Putting the new Number into the Stack\n
 231 | ???? | \n
 232 | 312E | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 233 | 312F |             add R3, R2, #0      ; Checking if R2 is 0\n
 234 | 3130 |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\n
 235 | 3131 |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\n
 236 | 3132 | D_LOOP      not R3, R2          ; Negating R2 into R3\n
