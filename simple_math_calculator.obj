LINE | ADDR | SOURCE
   0 | ???? | ; Simple Math Calculator\n
   1 | ???? | ; LC3-Based Reverse Polish Notation (RPN) Calculator\n
   2 | ???? | \n
   3 | ???? | ; Usage:\n
   4 | ???? | ; Enter a number 0-9, or an operator +, -, *, or /\n
   5 | ???? | ; Calculator will use Reverse Polish Notation to calculate\n
   6 | ???? | ; If there is only one number on stack, operation will fail\n
   7 | ???? | ; and program will terminate. It will accept up to 4 digits.\n
   8 | ???? | ; \".\" will copy the top of the RPN stack into result and terminate\n
   9 | ???? | ; If stack is empty, operation will fail and program will reset to the beginning\n
  10 | ???? | \n
  11 | ???? | ; Algorithm\n
  12 | ???? | ; 1. Initialize RPN stack and test values 0 - 9, +, -, *, /, and . \n
  13 | ???? | ; 2. Print title and instructions\n
  14 | ???? | ; 3. Read character from keyboard\n
  15 | ???? | ; 4. If operator, load operator vector, check stack for two numbers \n
  16 | ???? | ; 5. If so, execute operator vector and push result on stack, if not, error\n
  17 | ???? | ; 6. If number, push number onto stack\n
  18 | ???? | ; 7. If \".\", check if stack is empty, if not copy TOS to result, if so, error\n
  19 | ???? | ; 8. Loop back to 3\n
  20 | ???? | \n
  21 | ???? | ; Registers:\n
  22 | ???? | ; R0 - primary register for operations\n
  23 | ???? | ; R1 - temp register\n
  24 | ???? | ; R2 - temp register\n
  25 | ???? | ; R3 - temp register\n
  26 | ???? | ; R4 - RPN stack pointer\n
  27 | ???? | ; R5 - current number accumulator\n
  28 | ???? | ; R6 - digit counter\n
  29 | ???? | ; R7 - stores return addresses for JSR calls\n
  30 | ???? | \n
  31 | ???? | ; Prompts:\n
  32 | ???? | ;   > - ready to accept a new number\n
  33 | ???? | ;   ? - error occured, input doesn\'t make sense\n
  34 | ???? | ;   $ - stack error occurred\n
  35 | ???? | ;   ! - numeric overflow or underflow\n
  36 | ???? | \n
  37 | ???? | \n
  38 | ???? | .orig x3000\n
  39 | ???? | \n
  40 | 3000 | START       ld R4, STACK_TOP    ; RPN Stack Pointer Address\n
  41 | 3001 |             lea R0, MSG1        ; Printing Title and Instruction\n
  42 | 3002 |             puts\n
  43 | 3003 |             lea R0, MSG2\n
  44 | 3004 |             puts\n
  45 | 3005 |             lea R0, MSG3\n
  46 | 3006 |             puts\n
  47 | ???? |             \n
  48 | 3007 | LOOP        ld R0, NEWLINE\n
  49 | 3008 |             out\n
  50 | 3009 |             lea R0, NEW_NUM      ; Asking for a New Number/Operator\n
  51 | 300A |             puts\n
  52 | 300B |             getc\n
  53 | 300C |             out\n
  54 | 300D |             add R1, R0, #0      ; Transferring the new number to R1\n
  55 | 300E |             add R0, R1, #0      ; Transferring the number back to R0\n
  56 | ???? |             \n
  57 | 300F |             ld R1, MULT         ; Setting R1 to \"*\" and turning it to its negative decimal value\n
  58 | 3010 |             not R1, R1\n
  59 | 3011 |             add R1, R1, #1\n
  60 | 3012 |             add R2, R0, R1      ; If R2 is negative, that means the input is not a valid input (decimal value is too small)\n
  61 | 3013 |             brn ERROR\n
  62 | ???? |             \n
  63 | 3014 |             ld R1, ASCII_0      ; Setting R1 to ASCII 0 and turning it to its negative decimal value\n
  64 | 3015 |             not R1, R1\n
  65 | 3016 |             add R1, R1, #1\n
  66 | 3017 |             add R2, R0, R1      ; Since we checked the lower bound, anything less than ASCII 0 will be either a valid operator or \",\"\n
  67 | 3018 |             brn CHECK_OP\n
  68 | 3019 |             add R2, R2, #-9     ; If R2 is negative, that means the input is not a valid input (decimal value is too large)\n
  69 | 301A |             brp ERROR\n
  70 | ???? |             \n
  71 | 301B |             jsr BUILD_NUM       ; Input is a Number, time to get a 1 to 4 digit number\n
  72 | 301C |             brnzp LOOP\n
  73 | ???? | \n
  74 | 301D | result      .blkw 1             ; Result from the Calculator\n
  75 | ???? | \n
  76 | 301E | MSG1        .stringz \"SMC RPN Calculator\\n\"\n
  77 | 3032 | MSG2        .stringz \"Enter 0-9 or +, -, *, /, or . to display result on TOS.\\n\"\n
  78 | 306B | MSG3        .stringz \"It will accept up to 4 numeric digits and perform operations.\"\n
  79 | ???? | \n
  80 | 30A9 | BUILD_NUM   and R5, R5, #0      ; R5 = current number\n
  81 | 30AA |             and R6, R6, #0      ; R6 = digit count\n
  82 | ???? | \n
  83 | 30AB | BUILD_LOOP  ld R1, ASCII_0      ; convert ASCII digit to integer\n
  84 | 30AC |             not R1, R1\n
  85 | 30AD |             add R1, R1, #1\n
  86 | 30AE |             add R0, R0, R1      ; R0 = digit value\n
  87 | ???? | \n
  88 | 30AF |             add R1, R5, R5      ; Number + Number = 2(Number)\n
  89 | 30B0 |             add R2, R1, R1      ; 2(Number) + 2(Number) = 4(Number)\n
  90 | 30B1 |             add R2, R2, R2      ; 4(Number) + 4(Number) = 8(Number)\n
  91 | 30B2 |             add R5, R1, R2      ; 8(Number) + 2(Number) = 10(Number)\n
  92 | ???? | \n
  93 | 30B3 |             add R5, R5, R0      ; add digit\n
  94 | 30B4 |             add R6, R6, #1      ; increment digit count\n
  95 | 30B5 |             add R1, R6, #-4     ; check >4 digits\n
  96 | 30B6 |             brp F_ERROR\n
  97 | ???? | \n
  98 | 30B7 |             getc                ; get next char\n
  99 | 30B8 |             ld R1, ENTER        ; check ENTER\n
 100 | 30B9 |             not R1, R1\n
 101 | 30BA |             add R1, R1, #1\n
 102 | 30BB |             add R2, R0, R1\n
 103 | 30BC |             brz PUSH_BUILT\n
 104 | 30BD |             out\n
 105 | ???? | \n
 106 | 30BE |             ld R1, ASCII_0      ; check if digit\n
 107 | 30BF |             not R1, R1\n
 108 | 30C0 |             add R1, R1, #1\n
 109 | 30C1 |             add R2, R0, R1\n
 110 | 30C2 |             brn ERROR\n
 111 | ???? | \n
 112 | 30C3 |             add R2, R2, #-9\n
 113 | 30C4 |             brp ERROR\n
 114 | ???? | \n
 115 | 30C5 |             brnzp BUILD_LOOP\n
 116 | ???? | \n
 117 | 30C6 | PUSH_BUILT  add R4, R4, #-1\n
 118 | 30C7 |             str R5, R4, #0\n
 119 | 30C8 |             ret\n
 120 | ???? | \n
 121 | 30C9 | S_ERROR     lea R0, STACK_ERROR ; Stack Error\n
 122 | 30CA |             puts\n
 123 | 30CB |             brnzp START         ; Restarting Program\n
 124 | ???? | \n
 125 | 30CC | F_ERROR     lea R0, FLOW_ERROR  ; Numeric Overflow or Underflow\n
 126 | 30CD |             puts\n
 127 | 30CE |             brnzp START         ; Restarting Program\n
 128 | ???? | \n
 129 | 30CF | ERROR       lea R0, INPUT_ERROR ; Input Error\n
 130 | 30D0 |             puts\n
 131 | 30D1 |             brnzp START         ; Restarting Program\n
 132 | ???? | \n
 133 | 30D2 | EXIT        halt\n
 134 | ???? | \n
 135 | 30D3 | STACK_TOP   .fill x4000\n
 136 | 30D4 | NEW_NUM     .stringz \"> \"\n
 137 | 30D7 | INPUT_ERROR .stringz \"\\n?\\n\"\n
 138 | 30DB | STACK_ERROR .stringz \"\\n$\\n\"\n
 139 | 30DF | FLOW_ERROR  .stringz \"\\n!\\n\"\n
 140 | 30E3 | NEWLINE     .fill x000A\n
 141 | 30E4 | MULT        .fill x2A\n
 142 | 30E5 | PLUS        .fill x2B\n
 143 | 30E6 | MINUS       .fill x2D\n
 144 | 30E7 | DIVIDE      .fill x2F\n
 145 | 30E8 | TOS         .fill x2E\n
 146 | 30E9 | ASCII_0     .fill x30\n
 147 | 30EA | CURRENT_NUM .blkw 1\n
 148 | 30EB | DIGIT_COUNT .blkw 1\n
 149 | 30EC | NEG_TEN     .fill #-10\n
 150 | 30ED | ENTER       .fill x000A\n
 151 | ???? | \n
 152 | 30EE | DONE        ld R1, STACK_TOP    ; Checks if the Stack has Extra Numbers\n
 153 | 30EF |             not R2, R4\n
 154 | 30F0 |             add R2, R2, #1\n
 155 | 30F1 |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 156 | 30F2 |             add R3, R3, #-1     ; Finds the Remaining Amount of Numbers in the Stack after taking 1\n
 157 | 30F3 |             brnp S_ERROR        ; brnp checks if there is more than 1 number in the stack or 0 numbers in the stack\n
 158 | ???? |             \n
 159 | 30F4 |             ldr R0, R4, #0      ; Takes the current value in R4\n
 160 | 30F5 |             st R0, result       ; Stores it into result\n
 161 | 30F6 |             brnzp EXIT\n
 162 | ???? | \n
 163 | 30F7 | PUSH        add R4, R4, #-1     ; Decrementing the Stack\n
 164 | 30F8 |             str R0, R4, #0      ; Storing the New Number into the Stack\n
 165 | 30F9 |             brnzp LOOP\n
 166 | ???? | \n
 167 | 30FA | CHECK_OP    ld R1, TOS          ; Checking if the Operator is \".\"\n
 168 | 30FB |             not R1, R1\n
 169 | 30FC |             add R1, R1, #1\n
 170 | 30FD |             add R2, R0, R1\n
 171 | 30FE |             brz DONE\n
 172 | ???? |             \n
 173 | 30FF |             ld R1, STACK_TOP    ; Checks if the Stack has 2 Available Numbers to use for the Operation\n
 174 | 3100 |             not R2, R4\n
 175 | 3101 |             add R2, R2, #1\n
 176 | 3102 |             add R3, R1, R2      ; Finds the Amount of Numbers in the Stack\n
 177 | 3103 |             add R3, R3, #-2     ; Finds the Remaining Amount of Numbers in the Stack after taking 2\n
 178 | 3104 |             brn S_ERROR\n
 179 | ???? |             \n
 180 | 3105 |             ld R1, MULT         ; Checking if the Operator is the Multiplication Symbol\n
 181 | 3106 |             not R1, R1\n
 182 | 3107 |             add R1, R1, #1\n
 183 | 3108 |             add R2, R0, R1\n
 184 | 3109 |             brz MULTIPLY\n
 185 | ???? |             \n
 186 | 310A |             ld R1, PLUS         ; Checking if the Operator is the Addition Symbol\n
 187 | 310B |             not R1, R1\n
 188 | 310C |             add R1, R1, #1\n
 189 | 310D |             add R2, R0, R1\n
 190 | 310E |             brz ADDITION\n
 191 | ???? |             \n
 192 | 310F |             ld R1, MINUS        ; Checking if the Operator is the Subtraction Symbol\n
 193 | 3110 |             not R1, R1\n
 194 | 3111 |             add R1, R1, #1\n
 195 | 3112 |             add R2, R0, R1\n
 196 | 3113 |             brz SUBTRACTION\n
 197 | ???? |             \n
 198 | 3114 |             ld R1, DIVIDE       ; Checking if the Operator is the Division Symbol\n
 199 | 3115 |             not R1, R1\n
 200 | 3116 |             add R1, R1, #1\n
 201 | 3117 |             add R2, R0, R1\n
 202 | 3118 |             brz DIVISION\n
 203 | ???? |             \n
 204 | 3119 |             brnzp ERROR         ; Input is \",\" which is an disallowed input\n
 205 | ???? | \n
 206 | 311A | MULTIPLY    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 207 | 311B |             and R0, R0, #0      ; Sum of Repeated Addition to find the Product of R1 and R2\n
 208 | 311C | M_LOOP      add R2, R2, #0      ; Checking if R2 is at zero to end the loop\n
 209 | 311D |             brz PUSH            ; Putting the new Number into the Stack\n
 210 | 311E |             add R0, R0, R1      ; Repeated Addition\n
 211 | 311F |             add R2, R2, #-1     ; Decrementing R2 until it is 0\n
 212 | 3120 |             brnzp M_LOOP\n
 213 | ???? | \n
 214 | 3121 | ADDITION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 215 | 3122 |             add R0, R1, R2      ; Adding 2 Most Recent Numbers in the Stack\n
 216 | 3123 |             brnzp PUSH          ; Putting the new Number into the Stack\n
 217 | ???? | \n
 218 | 3124 | SUBTRACTION jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 219 | 3125 |             not R2, R2          ; Negating R2\n
 220 | 3126 |             add R2, R2, #1\n
 221 | 3127 |             add R0, R2, R1      ; Adding R1 and the Negation of R2\n
 222 | 3128 |             brnzp PUSH          ; Putting the new Number into the Stack\n
 223 | ???? | \n
 224 | 3129 | DIVISION    jsr POP2            ; Retrieving the 2 Most Recent Additions to the Stack\n
 225 | 312A |             add R3, R2, #0      ; Checking if R2 is 0\n
 226 | 312B |             brz ERROR           ; If R2 is 0, then Division by 0 which is an Error\n
 227 | 312C |             and R0, R0, #0      ; Counter of the amount of times R2 subtracts into R1\n
 228 | 312D |             and R3, R3, #0      ; Keeps record if the quotient should be positive (0) or negative (1)\n
 229 | 312E |             add R1, R1, #0\n
 230 | 312F |             brzp SKIP           ; Checks if R1 (dividend) is negative or not\n
 231 | 3130 |             not R1, R1\n
 232 | 3131 |             add R1, R1, #1      ; Negating R1\n
 233 | 3132 |             add R3, R3, #1      ; Changes R3 to negative\n
 234 | 3133 | SKIP        add R2, R2, #0\n
 235 | 3134 |             brzp D_LOOP         ; Checks if R2 (divisor) is negative or not\n
 236 | 3135 |             not R2, R2\n
 237 | 3136 |             add R2, R2, #1      ; Negating R2\n
 238 | 3137 |             add R3, R3, #1\n
 239 | 3138 | D_LOOP      not R5, R2          ; Negating R2 into R5 (R5 is a temp register here)\n
 240 | 3139 |             add R5, R5, #1\n
 241 | 313A |             add R1, R1, R5      ; Addition of R1 and Negation of R5\n
 242 | 313B |             brn D_DONE          ; If R1 is not negative yet, the loop repeats, otherwise make quotient the correct sign then push to stack\n
 243 | 313C |             add R0, R0, #1      ; Incrementing R1\n
 244 | 313D |             brnzp D_LOOP\n
 245 | 313E | D_DONE      add R3, R3, #-1\n
 246 | 313F |             brnp PUSH           ; If R3 was 0 or 2 originally (positive), then now it is -1 or 1 and will be pushed to stack\n
 247 | 3140 |             not R0, R0          ; Otherwise R0 will be negated\n
 248 | 3141 |             add R0, R0, #1\n
 249 | 3142 |             brnzp PUSH\n
 250 | ???? |             \n
 251 | 3143 | POP2        ldr R2, R4, #0      ; Retrieving the Last Number in the Stack\n
 252 | 3144 |             add R4, R4, #1      ; Incrementing the Stack\n
 253 | 3145 |             ldr R1, R4, #0      ; Retrieving the Next Last Number in the Stack\n
 254 | 3146 |             add R4, R4, #1      ; Incrementing the Stack\n
 255 | 3147 |             ret\n
 256 | ???? | .end
