LINE | ADDR | SOURCE
   0 | ???? | ; Simple Math Calculator\r\n
   1 | ???? | ; LC3-Based Reverse Polish Notation (RPN) Calculator\r\n
   2 | ???? | \r\n
   3 | ???? | ; Usage:\r\n
   4 | ???? | ; Enter a number 0-9, or an operator +, -, *, or /\r\n
   5 | ???? | ; Calculator will use Reverse Polish Notation to calculate\r\n
   6 | ???? | ; If there is only one number on stack, operation will fail\r\n
   7 | ???? | ; and program will terminate. It will accept up to 4 digits.\r\n
   8 | ???? | ; \".\" will copy the top of the RPN stack into result and terminate\r\n
   9 | ???? | ; If stack is empty, operation will fail and program will reset to the beginning\r\n
  10 | ???? | \r\n
  11 | ???? | ; Algorithm\r\n
  12 | ???? | ; 1. Initialize RPN stack and test values 0 - 9, +, -, *, /, and . \r\n
  13 | ???? | ; 2. Print title and instructions\r\n
  14 | ???? | ; 3. Read character from keyboard\r\n
  15 | ???? | ; 4. If operator, load operator vector, check stack for two numbers \r\n
  16 | ???? | ; 5. If so, execute operator vector and push result on stack, if not, error\r\n
  17 | ???? | ; 6. If number, push number onto stack\r\n
  18 | ???? | ; 7. If \".\", check if stack is empty, if not copy TOS to result, if so, error\r\n
  19 | ???? | ; 8. Loop back to 3\r\n
  20 | ???? | \r\n
  21 | ???? | ; Registers:\r\n
  22 | ???? | ; R0 - primary register for operations\r\n
  23 | ???? | ; R1 - temp register\r\n
  24 | ???? | ; R2 - temp register\r\n
  25 | ???? | ; R3 - temp register\r\n
  26 | ???? | ; R4 - RPN stack pointer\r\n
  27 | ???? | ; R5 - current number accumulator\r\n
  28 | ???? | ; R6 - digit counter\r\n
  29 | ???? | ; R7 - stores return addresses for JSR calls\r\n
  30 | ???? | \r\n
  31 | ???? | ; Prompts:\r\n
  32 | ???? | ;   > - ready to accept a new number\r\n
  33 | ???? | ;   ? - error occured, input doesn\'t make sense\r\n
  34 | ???? | ;   $ - stack error occurred\r\n
  35 | ???? | ;   ! - numeric overflow or underflow\r\n
  36 | ???? | \r\n
  37 | ???? | \r\n
  38 | ???? | .orig x3000\r\n
  39 | ???? | \r\n
  40 | 3000 | START       ld R4, STACK_TOP    ; RPN Stack Pointer Address\r\n
  41 | 3001 |             lea R0, MSG1        ; Printing Title and Instruction\r\n
  42 | 3002 |             puts\r\n
  43 | 3003 |             lea R0, MSG2\r\n
  44 | 3004 |             puts\r\n
  45 | 3005 |             lea R0, MSG3\r\n
  46 | 3006 |             puts\r\n
  47 | ???? |             \r\n
  48 | 3007 | LOOP        ld R0, NEWLINE\r\n
  49 | 3008 |             out\r\n
  50 | 3009 |             lea R0, NEW_NUM      ; Asking for a New Number/Operator\r\n
  51 | 300A |             puts\r\n
  52 | 300B |             getc\r\n
  53 | 300C |             out\r\n
  54 | 300D |             add R1, R0, #0      ; Transferring the new number to R1\r\n
  55 | 300E |             add R0, R1, #0      ; Transferring the number back to R0\r\n
  56 | ???? |             \r\n
  57 | 300F |             ld R1, MULT         ; Setting R1 to \"*\" and turning it to its negative decimal value\r\n
  58 | 3010 |             not R1, R1\r\n
  59 | 3011 |             add R1, R1, #1\r\n
  60 | 3012 |             add R2, R0, R1      ; If R2 is negative, that means the input is not a valid input (decimal value is too small)\r\n
  61 | 3013 |             brn ERROR\r\n
  62 | ???? |             \r\n
  63 | 3014 |             ld R1, ASCII_0      ; Setting R1 to ASCII 0 and turning it to its negative decimal value\r\n
  64 | 3015 |             not R1, R1\r\n
  65 | 3016 |             add R1, R1, #1\r\n
  66 | 3017 |             add R2, R0, R1      ; Since we checked the lower bound, anything less than ASCII 0 will be either a valid operator or \",\"\r\n
  67 | 3018 |             brn CHECK_OP\r\n
  68 | 3019 |             add R2, R2, #-9     ; If R2 is negative, that means the input is not a valid input (decimal value is too large)\r\n
  69 | 301A |             brp ERROR\r\n
  70 | ???? |             \r\n
  71 | 301B |             jsr BUILD_NUM       ; Input is a Number, time to get a 1 to 4 digit number\r\n
  72 | 301C |             brnzp LOOP\r\n
  73 | ???? | \r\n
  74 | 301D | result      .blkw 1             ; Result from the Calculator\r\n
  75 | ???? | \r\n
  76 | 301E | MSG1        .stringz \"SMC RPN Calculator\\n\"\r\n
  77 | 3032 | MSG2        .stringz \"Enter 0-9 or +, -, *, /, or . to display result on TOS.\\n\"\r\n
  78 | 306B | MSG3        .stringz \"It will accept up to 4 numeric digits and perform operations.\"\r\n
  79 | ???? | \r\n
  80 | 30A9 | BUILD_NUM   and R5, R5, #0      ; R5 = current number\r\n
  81 | 30AA |             and R6, R6, #0      ; R6 = digit count\r\n
  82 | ???? | \r\n
  83 | 30AB | BUILD_LOOP  ld R1, ASCII_0      ; convert ASCII digit to integer\r\n
  84 | 30AC |             not R1, R1\r\n
  85 | 30AD |             add R1, R1, #1\r\n
  86 | 30AE |             add R0, R0, R1      ; R0 = digit value\r\n
  87 | ???? | \r\n
  88 | 30AF |             add R1, R5, R5      ; Number + Number = 2(Number)\r\n
  89 | 30B0 |             add R2, R1, R1      ; 2(Number) + 2(Number) = 4(Number)\r\n
  90 | 30B1 |             add R2, R2, R2      ; 4(Number) + 4(Number) = 8(Number)\r\n
  91 | 30B2 |             add R5, R1, R2      ; 8(Number) + 2(Number) = 10(Number)\r\n
  92 | ???? | \r\n
  93 | 30B3 |             add R5, R5, R0      ; add digit\r\n
  94 | 30B4 |             add R6, R6, #1      ; increment digit count\r\n
  95 | 30B5 |             add R1, R6, #-4     ; check >4 digits\r\n
  96 | 30B6 |             brp F_ERROR\r\n
  97 | ???? | \r\n
  98 | 30B7 |             getc                ; get next char\r\n
  99 | 30B8 |             ld R1, ENTER        ; check ENTER\r\n
