 238 | 3134 |             add R1, R1, R3      ; Addition of R1 and Negation of R3\n
 239 | 3135 |             brn PUSH            ; If R1 is not negative yet, the loop repeats, otherwise puts the new Number into the Stack\n
 240 | 3136 |             add R0, R0, #1      ; Incrementing R1\n
 241 | 3137 |             brnzp D_LOOP\n
